{
    "name": "devpilot-shell",
    "private": true,
    "version": "0.1.0",
    "description": "Shell application (host) for DevPilot 2026 – Micro Frontend architecture using Vite Module Federation and Apollo GraphQL Gateway.",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext ts,tsx --max-warnings 0",
        "clean": "rm -rf node_modules dist .vite",
        "reset": "npm run clean && npm install",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@apollo/client": "^3.14.1",
        "bootstrap": "^5.3.8",
        "graphql": "^16.13.1",
        "react": "18.2.0",
        "react-bootstrap": "^2.10.10",
        "react-dom": "18.2.0",
        "react-router-dom": "^6.22.0"
    },
    "devDependencies": {
        "@originjs/vite-plugin-federation": "^1.3.5",
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.34.0",
        "typescript": "^5.4.0",
        "vite": "^5.1.0"
    },
    "engines": {
        "node": ">=18"
    }
}